# =============================================================================
# TA-DSS: Post-Trade Position Monitoring System - Git Ignore
# =============================================================================
# Purpose: Exclude sensitive, generated, and runtime files from version control
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT & SECRETS (CRITICAL - NEVER COMMIT)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# VIRTUAL ENVIRONMENTS
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv/
.venv/
.pyenv/

# -----------------------------------------------------------------------------
# PYTHON CACHE & BUILD ARTIFACTS
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# IDE & EDITOR FILES
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# DATABASE FILES (APPLICATION DATA)
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
data/*.db
data/*.sqlite
data/*.db-shm
data/*.db-wal
*.sql
dump.sql

# -----------------------------------------------------------------------------
# LOG FILES (RUNTIME ARTIFACTS)
# -----------------------------------------------------------------------------
*.log
logs/
logs/*.log
log/
log/*.log

# -----------------------------------------------------------------------------
# TESTING & COVERAGE
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# -----------------------------------------------------------------------------
# JUPYTER NOTEBOOKS
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# STREAMLIT
# -----------------------------------------------------------------------------
.streamlit/secrets.toml

# -----------------------------------------------------------------------------
# OS GENERATED FILES
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# DOCKER & CONTAINERS
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# Docker runtime files (keep Dockerfile and configs)
docker/*.log
docker/*.tar
docker/*.gz

# -----------------------------------------------------------------------------
# MYPI & TYPE CHECKING
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# -----------------------------------------------------------------------------
# MISC RUNTIME FILES
# -----------------------------------------------------------------------------
*.pid
*.lock
*.lockfile
*.tmp
*.temp
.cache/
.tmp/
.temp/

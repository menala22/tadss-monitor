# TA-DSS: Post-Trade Position Monitoring System
# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# =============================================================================
# TELEGRAM NOTIFICATIONS
# =============================================================================
# Get bot token from @BotFather on Telegram
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token (looks like: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (use @userinfobot to find your ID)
# 1. Open Telegram and search for @userinfobot
# 2. Start the bot and it will show your ID
# 3. Copy the ID (looks like: 123456789)
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# DATABASE
# =============================================================================
# SQLite (MVP)
DATABASE_URL=sqlite:///./positions.db

# PostgreSQL (Production) - uncomment and configure when ready
# DATABASE_URL=postgresql://user:password@localhost:5432/tadss_db

# =============================================================================
# DATA SOURCE APIS
# =============================================================================
# CCXT (Crypto) - No API key needed for public market data
# Only required if using authenticated endpoints (trading, balances)
# Exchange options: kraken, binance, bybit, kucoin, etc.
# Kraken is recommended for global availability (no geo-restrictions)
CCXT_EXCHANGE=kraken
CCXT_API_KEY=your_ccxt_api_key_here
CCXT_SECRET=your_ccxt_secret_here

# Twelve Data (Stocks/Forex/Metals) - Free tier: 800 API calls/day
# Supports: XAU/USD (Gold), XAG/USD (Silver), Stocks, Forex
# Sign up at: https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# yfinance (Stocks) - No API key needed for basic usage
# Optional: Yahoo Finance API key for premium features
# Note: May be geo-restricted on cloud VMs (AWS, GCP, Azure)
YFINANCE_API_KEY=your_yfinance_api_key_here

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# FastAPI environment
APP_ENV=development
# APP_ENV=production

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Server host and port
HOST=0.0.0.0
PORT=8000

# =============================================================================
# DASHBOARD CONFIGURATION
# =============================================================================
# API Base URL for Dashboard connection
# - Local development (default): http://localhost:8000/api/v1
# - Production (Google Cloud): http://VM_EXTERNAL_IP:8000/api/v1
#
# Get VM External IP from Google Cloud Console:
#   Compute Engine → VM Instances → Find your VM → External IP
#
# Usage:
#   Local:   streamlit run src/ui.py --server.port 8503
#   Prod:    API_BASE_URL=http://VM_EXTERNAL_IP:8000/api/v1 streamlit run src/ui.py --server.port 8503
API_BASE_URL=http://localhost:8000/api/v1

# Google Cloud VM External IP (for production deployment)
# This IP is used by the production script and dashboard
VM_EXTERNAL_IP=your_vm_external_ip_here

# =============================================================================
# SCHEDULER
# =============================================================================
# Monitoring interval is now FIXED at 1 hour (runs at :10 past every hour)
# This avoids API congestion at round hour boundaries (:00)
# To change the schedule, modify the cron trigger in src/scheduler.py

TIMEZONE=UTC

# =============================================================================
# SECURITY
# =============================================================================
# Secret key for session signing (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# CORS allowed origins (JSON array format - IMPORTANT!)
# Must be a valid JSON array with double quotes
CORS_ORIGINS=["http://localhost:8501","http://localhost:8000"]

# =============================================================================
# RATE LIMITING (Optional)
# =============================================================================
# Requests per minute for API endpoints
RATE_LIMIT=60
